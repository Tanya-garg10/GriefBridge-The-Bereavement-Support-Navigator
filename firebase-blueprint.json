{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with custom support preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The firebase auth user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "Display nickname" },
        "avatar": { "type": "string", "description": "URL of user avatar" },
        "transitionType": { "type": "string", "description": "Type of transitional grief" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "displayName", "avatar", "transitionType", "createdAt"]
    },
    "Journal": {
      "title": "Journal",
      "description": "Emotional journal entry analyzed by Gemini AI",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique journal ID" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "title": { "type": "string", "description": "Title generated by AI or user" },
        "text": { "type": "string", "description": "Plain text content of the entry" },
        "hasAudio": { "type": "boolean", "description": "Flag for voice-to-text input" },
        "overallMoodScore": { "type": "integer", "description": "Overall mood from 1 to 10" },
        "dominantEmotion": { "type": "string", "description": "Dominant emotion identified" },
        "keywords": { "type": "array", "description": "Key vocabulary items" },
        "aiResponse": { "type": "string", "description": "AI compassionate feedback" },
        "date": { "type": "string", "description": "Local calendar date yyyy-mm-dd" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "title", "text", "hasAudio", "overallMoodScore", "dominantEmotion", "keywords", "aiResponse", "date", "createdAt"]
    },
    "Checkin": {
      "title": "Checkin",
      "description": "Daily well-being numeric tracking log",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log ID" },
        "userId": { "type": "string", "description": "User identifier" },
        "moodScore": { "type": "integer", "description": "Mood score from 1 to 10" },
        "subMoods": { "type": "array", "description": "Adjectives describing the state" },
        "sleepHours": { "type": "integer", "description": "Hours of sleep logged" },
        "physicalActivity": { "type": "boolean", "description": "Whether physical exercise occurred" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "moodScore", "subMoods", "sleepHours", "physicalActivity", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "Forum community post",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID" },
        "category": { "type": "string", "description": "Post category" },
        "title": { "type": "string", "description": "Title of post" },
        "body": { "type": "string", "description": "Full post body content" },
        "authorId": { "type": "string", "description": "User ID of author" },
        "authorName": { "type": "string", "description": "Author name or pseudonym" },
        "authorAvatar": { "type": "string", "description": "Author portrait URL" },
        "anonymous": { "type": "boolean", "description": "Whether to mask author identity" },
        "likes": { "type": "integer", "description": "Amount of net likes" },
        "likedBy": { "type": "array", "description": "List of user IDs who liked" },
        "tags": { "type": "array", "description": "Categorization tags" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Publish timestamp" }
      },
      "required": ["id", "category", "title", "body", "authorId", "authorName", "authorAvatar", "anonymous", "likes", "likedBy", "tags", "createdAt"]
    },
    "Reply": {
      "title": "Reply",
      "description": "Reply comment details on forum post",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique reply ID" },
        "postId": { "type": "string", "description": "Anchor post ID" },
        "body": { "type": "string", "description": "Reply content text" },
        "authorId": { "type": "string", "description": "User ID of creator" },
        "authorName": { "type": "string", "description": "Nickname or anonymous support label" },
        "authorAvatar": { "type": "string", "description": "Portrait URL" },
        "anonymous": { "type": "boolean", "description": "Anonymity toggle" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp created" }
      },
      "required": ["id", "postId", "body", "authorId", "authorName", "authorAvatar", "anonymous", "createdAt"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Professional support therapist or community organization resource representation",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Resource identifier" },
        "name": { "type": "string", "description": "Resource name" },
        "type": { "type": "string", "description": "Resource category classification" },
        "address": { "type": "string", "description": "Physical address location" },
        "description": { "type": "string", "description": "Target profile bio" },
        "phone": { "type": "string", "description": "Contact telephone" },
        "website": { "type": "string", "description": "Reference hyperlink" },
        "latitude": { "type": "number", "description": "Latitude float coordinate" },
        "longitude": { "type": "number", "description": "Longitude float coordinate" },
        "cost": { "type": "string", "description": "Sliding scale, paid, or free" },
        "specialization": { "type": "array", "description": "Matching grief categories" },
        "languages": { "type": "array", "description": "Offered dialects" },
        "rating": { "type": "number", "description": "Professional user feedback score" }
      },
      "required": ["id", "name", "type", "description", "phone", "website", "latitude", "longitude", "cost", "specialization", "languages", "rating"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection storing user profiles keyed by authorization uid"
    },
    "journals/{journalId}": {
      "schema": "Journal",
      "description": "Collection tracking user emotional journals with AI feedback fields"
    },
    "checkins/{checkinId}": {
      "schema": "Checkin",
      "description": "Collection logging daily mood scores and somatic inputs"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Master list of support forum threads and issues raised"
    },
    "posts/{postId}/replies/{replyId}": {
      "schema": "Reply",
      "description": "Sub-collection of comments offering solidarity on a specific forum post"
    },
    "resources/{resourceId}": {
      "schema": "Resource",
      "description": "Offered expert support systems, NGOs and local counselors map markers"
    }
  }
}
